# Runtime environment: local, test, staging, or production
APP_ENV=local

# Leave blank. `make dev` runs the backend in a container where compose.yaml
# overrides this with the containerized PostgreSQL (ec_site@db:5432). Host-run
# tools (pytest, `make dev-host`) fall back to backend/app/data/ec_site.db.
# To reach the compose PostgreSQL from the host: postgresql+psycopg://ec_site:ec_site@127.0.0.1:5432/ec_site
DATABASE_URL=

# Secrets are intentionally blank. Local development uses a known fallback;
# production requires an explicit value of at least 32 characters.
SECRET_KEY=

FRONTEND_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5174
LOG_LEVEL=INFO

# Stripe is optional locally. Enabling it requires a secret key.
# The webhook secret is required in production when Stripe is enabled
# (signature verification for POST /payment/webhook).
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# console, disabled, or smtp. SMTP settings are required only for smtp.
EMAIL_DELIVERY=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@techstore.local

# This value is public and is embedded in the browser bundle.
VITE_API_URL=http://localhost:8001
