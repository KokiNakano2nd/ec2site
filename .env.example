# Runtime environment: local, test, staging, or production
APP_ENV=local

# Leave blank in local development to use backend/app/data/ec_site.db.
DATABASE_URL=

# Secrets are intentionally blank. Local development uses a known fallback;
# production requires an explicit value of at least 32 characters.
SECRET_KEY=

FRONTEND_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5174
LOG_LEVEL=INFO

# Stripe is optional locally. Enabling it requires a secret key.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=

# console, disabled, or smtp. SMTP settings are required only for smtp.
EMAIL_DELIVERY=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@techstore.local

# This value is public and is embedded in the browser bundle.
VITE_API_URL=http://localhost:8001
